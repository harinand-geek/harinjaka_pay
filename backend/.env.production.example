APP_NAME="Digital Subscription Pay"
APP_ENV=production
# Generate on the server with: php artisan key:generate
APP_KEY=
APP_DEBUG=false
APP_URL=https://pay.digitalsub.org

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

# Same origin as the API (mono-domain) — kept for CORS completeness.
FRONTEND_URL=https://pay.digitalsub.org

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=parcour3_digitalsubpay
DB_USERNAME=parcour3_digitalsubpay
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Bearer-token auth — stateful domains not required for the SPA.
SANCTUM_STATEFUL_DOMAINS=pay.digitalsub.org

BROADCAST_CONNECTION=log
# Public disk so uploaded logos are served via /storage (run: php artisan storage:link)
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file

# Privacy: hash visitor IPs. Set a long random string.
ANALYTICS_IP_SALT=change-this-to-a-long-random-string
GEO_LOOKUP_ENABLED=false

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@digitalsub.org"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
